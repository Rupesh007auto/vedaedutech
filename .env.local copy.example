# ============================================
# VedaEdutech - Environment Variables
# Copy this file to .env.local and fill in real values.
# ============================================

# --- MongoDB Atlas (required) ---
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# Must be a single line, no line breaks.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vedaedutech?retryWrites=true&w=majority

# --- NextAuth (required) ---
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# --- Site URL (required for SEO metadata, sitemap, OG tags) ---
NEXT_PUBLIC_SITE_URL=https://www.vedaedutech.in

# --- Contact / WhatsApp (required for floating buttons + contact page) ---
NEXT_PUBLIC_WHATSAPP_NUMBER=914040188140
NEXT_PUBLIC_PHONE_DISPLAY="+91 40 4018 8140"
NEXT_PUBLIC_PHONE_TEL=+914040188140
NEXT_PUBLIC_CONTACT_EMAIL=info@vedavaag.com

# --- Google Maps embed (no API key required for basic /maps?q= embed) ---
NEXT_PUBLIC_MAP_QUERY="HITEC City, Hyderabad"

# --- UploadThing (required for Gallery & Blog image uploads, and resume uploads) ---
# Create a free account at https://uploadthing.com, create an app, and copy these from
# the API Keys tab.
UPLOADTHING_SECRET=sk_live_xxxxxxxxxxxxxxxxxxxx
UPLOADTHING_APP_ID=your_app_id

# --- Resend (required for password-reset emails) ---
# Create a free account at https://resend.com and verify a sending domain.
# If left blank, reset links are logged to the server console instead of emailed
# (useful for local development).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="VedaEdutech <no-reply@vedaedutech.in>"
